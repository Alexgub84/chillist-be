  "changelog": {
    "1.4": [
      "Added selection_by_tier — explicit single vs multi (and per-flag / per-axis breakdown) for FE at-a-glance.",
      "Added tier3.select ('per_parent'), tier3.default_select ('single'), and duplicated multi_select_parents under selection_by_tier.tier3 for consistency."
    ],
    "1.3": [
      "Added group_character.contradictions — pairs of option ids that cannot both be selected. FE should deselect the previous choice when a contradicting option is picked.",
      "Added tier3.multi_select_parents — array of tier2 option ids whose tier3 drill-downs allow multi-select. All other tier3 groups are single-select.",
      "Fixed all_inclusive tier3: replaced ambiguous 'ai_drinks_included' add-on with 'ai_drinks_only' as a proper single-select alternative to board options.",
      "Updated structural_contract and design_principles to document the new selection rules."
    ],
    "1.2": [
      "Added bilingual labels (en + he) to all user-facing strings.",
      "All 'label' fields now follow the shape { en, he }.",
      "item_generation_bundles.travel_abroad items are now bilingual objects instead of plain strings.",
      "Structural contract updated to document the label shape guarantee."
    ],
    "1.1": [
      "Restructured Tier 2 into named axes (sleep, food_strategy, activities, venue) — each internally single-select.",
      "Split 'hotel_trip' into 'hotel_stay' and 'airbnb_stay'.",
      "Promoted 'games_gathering' and 'party' to Tier 1.",
      "Removed Tier 1 'Other'.",
      "Added universal flags 'destination_scope' and 'group_character'.",
      "Added per-Tier-1 defaults and hidden_options for sensible pre-selection.",
      "Added structural_contract block."
    ]
  }
}
