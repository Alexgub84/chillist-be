      { "id": "airbnb_stay",     "label": { "en": "Airbnb / Rental House",     "he": "Airbnb / צימר" },        "emoji": "🏡" },
      { "id": "hiking",          "label": { "en": "Hiking / Trekking",         "he": "טרק / טיול רגלי" },      "emoji": "🥾" },
      { "id": "road_trip",       "label": { "en": "Road Trip",                 "he": "רוד טריפ" },             "emoji": "🚗" },
      { "id": "day_trip",        "label": { "en": "Day Trip / Outing",         "he": "טיול יום" },             "emoji": "🌅" },
      { "id": "beach_day",       "label": { "en": "Beach Day",                 "he": "יום ים" },               "emoji": "🏖️" },
      { "id": "city_day",        "label": { "en": "City Day / Sightseeing",    "he": "יום בעיר" },             "emoji": "🏙️" },
