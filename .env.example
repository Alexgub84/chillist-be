# Server
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Database
# Internal URL (used by app deployed on Railway, set in Railway env vars)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chillist
# Optional: Supabase user UUID to link owner participant so you appear as owner when logged in.
# Get your user ID from Supabase dashboard or auth.users table after sign-up.
# For local: set in .env.local; seed script auto-loads .env.local when present.
SEED_OWNER_USER_ID=
# Railway production uses internal URL (set via variable reference):
# DATABASE_URL=postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_PRIVATE_DOMAIN}}:5432/${{PGDATABASE}}

# Public URL (used for running migrations from local machine)
# Get from Railway dashboard: Postgres service > Connect > Public Networking
DATABASE_URL_PUBLIC=

# Frontend URL for CORS (in production, set to your actual frontend domain)
FRONTEND_URL=http://localhost:5173

# Supabase Auth
# Project URL from Supabase dashboard (Settings > API)
# Backend uses this to fetch JWKS public keys for JWT verification
# Required in production, optional in development
SUPABASE_URL=

# WhatsApp (Green API)
# Provider: 'green_api' for production, 'fake' for dev/test (logs only, no real messages)
WHATSAPP_PROVIDER=fake
# Required when WHATSAPP_PROVIDER=green_api
# Get from https://green-api.com dashboard
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=

# Internal Service-to-Service Auth (Chatbot)
# Shared secret between the chatbot server and this API — used to protect /api/internal/* routes
# Generate with: openssl rand -hex 32
# Required in production. For local dev, set any non-empty string.
CHATBOT_SERVICE_KEY=

# AI Item Suggestions
# Provider: 'anthropic' (default) or 'openai'
AI_PROVIDER=anthropic
# Required in production when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Required in production when AI_PROVIDER=openai
OPENAI_API_KEY=

# Supabase Admin (for phone → userId lookup on /api/internal/auth/identify)
# Service role key from Supabase dashboard: Project Settings > API > service_role
# WARNING: This key bypasses Row Level Security — never expose it to the frontend or commit it to code
# Required in production.
SUPABASE_SERVICE_ROLE_KEY=

